{
  "name": "@bdt/native-input",
  "private": true,
  "version": "0.1.0",
  "description": "C++ N-API addon for Win32 SendInput + typed InputController.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "gypfile": true,
  "scripts": {
    "build": "node-gyp rebuild && tsc -p tsconfig.json",
    "build:ts": "tsc -p tsconfig.json",
    "build:native": "node-gyp rebuild",
    "clean": "node-gyp clean && rimraf dist build",
    "test": "tsx --test ts/index.test.ts"
  },
  "files": [
    "dist",
    "build/Release/*.node",
    "src",
    "binding.gyp"
  ],
  "dependencies": {
    "node-addon-api": "^8.3.1"
  },
  "devDependencies": {
    "node-gyp": "^11.2.0",
    "rimraf": "^6.0.1",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "@types/node": "^22.10.0"
  }
}
